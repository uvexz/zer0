APP_ORIGIN=http://localhost:3000
AUTH_SECRET=zer0-dev-auth-secret-change-me-please
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zer0
# Optional. Maximum Postgres connections per process. Defaults to 4, or 1 on Vercel.
DATABASE_MAX_CONNECTIONS=
# Optional. Public federation GET responses default to a 120 second Redis TTL.
FEDERATION_CACHE_TTL_SECONDS=
REDIS_URL=redis://localhost:6379
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=.localdata/media

# Docker Compose configuration. Set ZER0_DATABASE_URL/ZER0_REDIS_URL only when
# Docker should use different services than DATABASE_URL/REDIS_URL.
ZER0_IMAGE=ghcr.io/uvexz/zer0:latest
ZER0_PORT=3000
POSTGRES_DB=zer0
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ZER0_DATABASE_URL=
ZER0_REDIS_URL=
ZER0_MEDIA_LOCAL_DIR=/data/media

# S3 or S3-compatible object storage. Set MEDIA_STORAGE_DRIVER=s3 to enable.
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_ENDPOINT=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_S3_PUBLIC_BASE_URL=
MEDIA_S3_FORCE_PATH_STYLE=false

# Optional. Set every SMTP_* value to enable password reset and email verification flows.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
