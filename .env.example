APP_ORIGIN=http://localhost:3000
AUTH_SECRET=zer0-dev-auth-secret-change-me-please
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zer0
REDIS_URL=redis://localhost:6379
MEDIA_STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=.localdata/media

# S3 or S3-compatible object storage. Set MEDIA_STORAGE_DRIVER=s3 to enable.
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_ENDPOINT=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_S3_PUBLIC_BASE_URL=
MEDIA_S3_FORCE_PATH_STYLE=false

# Optional for password reset flows.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
